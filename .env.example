# 💎 Famiglia Demo Environment Configuration
# Copy this file to .env and fill in the missing values

# --- Application Configuration ---
APP_ENV=development

# --- Database Credentials ---
DB_USER=passione_admin
DB_PASSWORD=passione_password
DB_NAME=passione_db



# --- LLM API Keys (Strictly Confidential) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# --- Slack Bot Tokens ---
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN_ALFREDO=
SLACK_BOT_TOKEN_VITO=
SLACK_BOT_TOKEN_RICCARDO=
SLACK_BOT_TOKEN_ROSSINI=
SLACK_BOT_TOKEN_TOMMY=
SLACK_BOT_TOKEN_BELLA=
SLACK_BOT_TOKEN_KOWALSKI=
SLACK_BOT_TOKEN_SYSTEM=

# --- Slack Individual App Tokens (Optional) ---
SLACK_APP_TOKEN_ALFREDO=
SLACK_APP_TOKEN_VITO=
SLACK_APP_TOKEN_RICCARDO=
SLACK_APP_TOKEN_ROSSINI=
SLACK_APP_TOKEN_TOMMY=
SLACK_APP_TOKEN_BELLA=
SLACK_APP_TOKEN_KOWALSKI=

# --- User Identification ---
USER_SLACK_ID=

# --- Ollama Configuration ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_FALLBACK_MODEL=gemma3:4b
OLLAMA_API_KEY=

# --- GitHub Integration (App Credentials) ---
GITHUB_APP_ID_RICCARDO=
GITHUB_APP_INSTALLATION_ID_RICCARDO=
GITHUB_APP_PRIVATE_KEY_RICCARDO=

GITHUB_APP_ID_ROSSINI=
GITHUB_APP_INSTALLATION_ID_ROSSINI=
GITHUB_APP_PRIVATE_KEY_ROSSINI=

# --- Notion Integration ---
NOTION_API_KEY_ROSSINI=
NOTION_API_KEY_KOWALSKI=



# --- System Defaults ---
AGENT_CONTEXT_ENABLED=true
DUCKDB_DWH_PATH=/app/data/duckdb_dwh.db
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
